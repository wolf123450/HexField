{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HexField",
  "version": "../package.json",
  "identifier": "com.hexfield.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HexField",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' wss: ws: https: ipc://localhost http://ipc.localhost http://localhost:*; media-src 'self' blob:; img-src 'self' data: blob: https://cdn.jsdelivr.net; font-src 'self' data:"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {}

  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": { "schemes": ["hexfield"] }
    },
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_TAURI_SIGNING_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/YOUR_ORG/hexfield/releases/latest/download/latest.json"
      ]
    }
  }
}
