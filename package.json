    "@tauri-apps/plugin-updater": "^2.10.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/uuid": "^10.0.0",
    "date-fns": "^3.6.0",
    "libsodium-wrappers": "^0.7.15",
    "libsodium-wrappers-sumo": "^0.8.2",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
